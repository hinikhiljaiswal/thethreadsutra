{
  "name": "thethreadsutra",
  "private": true,
  "version": "0.1.0",
  "description": "The Thread Sutra garments marketplace monorepo.",
  "scripts": {
    "dev": "concurrently -k -n api,web,mobile -c cyan,green,magenta \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:mobile\"",
    "dev:all": "npm run dev",
    "dev:stack": "concurrently -k -n api,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "dev:mobile": "npm run start -w apps/mobile",
    "render:build": "npm install && node scripts/render-build.js",
    "render:start": "node scripts/render-start.js",
    "render:build:api": "npm install && npm run build -w @thethreadsutra/api",
    "render:build:web": "npm install && npm run build -w @thethreadsutra/web",
    "render:start:api": "npm run start:prod -w apps/api",
    "render:start:web": "npm run start:render -w @thethreadsutra/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

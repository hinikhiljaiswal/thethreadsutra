PORT=4000
CORS_ORIGIN=http://localhost:3000

# Add this after MongoDB is running locally or in the cloud:
# MONGODB_URI=mongodb://127.0.0.1:27017/thethreadsutra

# Flipkart Seller API for DMILLS Global
# FLIPKART_API_KEY=
# FLIPKART_API_SECRET=
#
# Older internal aliases also work:
# FLIPKART_APP_ID=
# FLIPKART_APP_SECRET=
#
# Optional. Required only for location-specific inventory/fulfillment operations:
# FLIPKART_SELLER_ID=
# FLIPKART_LOCATION_ID=
